class Solution(object):
    def subarraySum(self, nums, k):
        prefix = 0
        count = 0
        prefix_count = {0:1}
        for num in nums:
            prefix += num
            if prefix - k in prefix_count:
                count += prefix_count[prefix-k]
            prefix_count[prefix] = prefix_count.get(prefix,0) + 1
        return count
