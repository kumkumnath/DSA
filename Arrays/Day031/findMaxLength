class Solution(object):
    def findMaxLength(self, nums):
      count = 0
      max_length = 0
      first_index = {0:-1}
      for i in range(len(nums)):
          if nums[i] == 0:
             count-=1
          else:
             count +=1
          if count in first_index:
              max_length = max(max_length, i-first_index[count])
          else:
             first_index[count] = i
      return max_length
      

        
