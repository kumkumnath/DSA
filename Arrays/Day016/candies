class Solution(object):
    def kidsWithCandies(self,candies,extraCandies):
        result = []
        max_candies = max(candies)

        for i in candies:
            new_candies = i + extraCandies

            if new_candies >= max_candies:
               result.append(True)
            else:
               result.append(False)

        return result
